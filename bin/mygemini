#!/usr/bin/perl

# Runs an interactive gemini-cli session, piping output through some filters.
# Specifically, we process any instances of ^[]2;<title>^G, which resets the
# terminal's title.  We use `script` to run interactively.  Since `script`
# does not permit passing additional arguments, we must escape everything
# properly, as in
#
#     script -c 'gemini '\''foo'\'' '\''bar baz'\'' '\''qu"'\''\'\'''\''ux'\''

use strict;
use warnings;
use utf8;
binmode(STDOUT, ':utf8');
binmode(STDIN, ':utf8');

use IO::Handle;

$| = 1;

# Read any existing title.
my $base_title = $ENV{MY_TERMINAL_TITLE} || 'G:' . `basename $(pwd)`;
chomp $base_title;

sub main {
  # Figure out the command to run.
  my $cmd = $ENV{GEMINI_COMMAND} || escape_word(`command -v gemini`);
  chomp $cmd;
  my @args = map { escape_word($_) } @ARGV;
  $cmd .= " @args";

  print STDERR "\e[1;30mscript -e -c '$cmd' /dev/null |\e[m\n";
  open my $pipe, '-|:utf8', 'script', '-e', '-c', $cmd, '/dev/null'
      or die "Could not open pipe: $!";
  $pipe->autoflush(1);

  open LOG, '>:utf8', '/tmp/GEMINI.LOG';
  open OUT, '>:utf8', '/tmp/GEMINI.OUT';
  my $buffer = '';
  while ($_ = <$pipe>) {
    print LOG $_;
    $_ = "$buffer$_";
    $buffer = '';
    # Look for any partial matches at the end of the input
    while (s/(?:\r|\e(?:\][^\a]*)?)$//) { $buffer = "$&$buffer"; }
    # Look for \e]2;<message>\a
    s/(\e][02];)(.*?)(\a)/$1 . process_title($2) . $3/eg;
    # Change \r\n into \n
    s/\r\n/\n/g;
    print OUT $_;
    print;
  }
  close $pipe or exit(($? >> 8) || 1);
  close LOG;
  close OUT;
}

sub escape_word {
  local($_) = shift;
  return $_ if /^[-a-z0-9_@+=,.\/[\]{}]+$/;
  s/'/'\\''/g;
  return "'$_'";
}

sub process_title {
  local($_) = shift;
  my $emoji = '✦';
  if (/[✋◇✦]/u) {
    my $x = $&;
    $x =~ s/✦/⏳/u;
    $emoji = $x;
  }
  return "$base_title $emoji";
}

main();
